# Copy this file to `.env` (Lab 1's Step 1 writes the real connection string for you).
# All platform services read it via load_dotenv() in telemetry.py.
#
# When this is set, every service exports logs/traces/metrics to Azure Monitor and appears
# as a distinct node in the Application Map. When it is unset, the whole platform runs in
# DEMO MODE (Lab 0) — fully functional, but emitting no telemetry.
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/;LiveEndpoint=https://<region>.livediagnostics.monitor.azure.com/
